---
const highlights = [
  { icon: "🎤", title: "AforShow 2023", subtitle: "Conferencista en Twitch", desc: "+300 espectadores en charla sobre desarrollo en LATAM" },
  { icon: "🎭", title: "Barrio Teatro", subtitle: "Gestión de Proyecto 2023", desc: "Lideré equipos multidisciplinarios para reducir violencia con soluciones culturales." },
  { icon: "🎓", title: "Educación", subtitle: "Ing. de Sistemas ", desc: "Universidad Nacional de Cajamarca" },
  { icon: "🗣️", title: "Idiomas", subtitle: "Nativo y Avanzado", desc: "Español (Nativo), Inglés (Avanzado)" },
];

const experienceYears = Math.floor((new Date() - new Date('2021-09-01')) / (1000 * 60 * 60 * 24 * 365.25));

const stats = [
  { value: `${experienceYears}+`, label: "Años de experiencia" },
  { value: "2", label: "Empresas multinacionales" },
  { value: "300+", label: "Audiencia en eventos" },
  { value: "30%", label: "Mejora en rendimiento DB" },
];

const certifications = [
  "Scrum Foundation Professional Certificate",
  "Remote Work Professional Certification",
  "Next.js: Framework De React Para Producción",
  "TypeScript Y Práctica Canvas 2021",
  "Vue.js: De Cero A Experto",
  "Docker Avanzado",
  "PostgreSQL & Java Spring"
];
---

<section id="about" class="py-24 px-6">
  <div class="max-w-5xl mx-auto">
    <div class="flex items-center gap-4 mb-14">
      <div class="h-px flex-1 bg-gradient-to-r from-transparent to-violet-500/40"></div>
      <h2 class="section-title"><span class="text-violet-400">01.</span> Sobre Mí</h2>
      <div class="h-px flex-1 bg-gradient-to-l from-transparent to-violet-500/40"></div>
    </div>

    <div class="grid md:grid-cols-2 gap-12 items-start">
      <div class="flex flex-col gap-5 text-slate-400 leading-relaxed">
        <p>Soy un <span class="text-white font-semibold">Software Engineer</span> con más de <span class="text-cyan-400 font-semibold">{experienceYears} años de experiencia</span> en desarrollo de software, con dominio <span class="text-slate-300 font-medium">full-stack</span> en Node.js, Python, Java y Linux — usando React, NestJS, Spring Boot y PostgreSQL.</p>
        <p>Especializado en la creación de soluciones escalables y eficientes tanto en el <span class="text-lime-400">frontend como en el backend</span>, impulsando la calidad del código, metodologías ágiles e integraciones sólidas.</p>
        <p>He <span class="text-white font-medium">liderado equipos multidisciplinarios</span> fomentando la colaboración y la innovación, asegurando el éxito y la escalabilidad de los proyectos en diversas industrias.</p>
      </div>

      <div class="grid grid-cols-2 gap-4">
        {stats.map((stat) => (
          <div class="glass-card group rounded-2xl p-6 text-center hover:border-cyan-500/40 hover:scale-105 transition-all duration-300">
            <div class="text-4xl font-extrabold bg-gradient-to-r from-violet-400 to-cyan-400 text-transparent bg-clip-text">
              {stat.value}
            </div>
            <div class="text-slate-400 text-sm mt-1 leading-snug">{stat.label}</div>
          </div>
        ))}
      </div>
    </div>

    <div class="mt-16 grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
      {highlights.map((h) => (
        <div class="glass-card rounded-2xl p-5 hover:border-violet-500/50 hover:scale-[1.03] transition-all duration-300 group">
          <div class="text-3xl mb-3">{h.icon}</div>
          <div class="text-white font-bold text-lg group-hover:text-violet-300 transition-colors">{h.title}</div>
          <div class="text-cyan-400 text-xs font-medium mt-0.5 mb-2">{h.subtitle}</div>
          <div class="text-slate-400 text-sm">{h.desc}</div>
        </div>
      ))}
    </div>

    <div class="mt-12 glass-card rounded-2xl p-6">
      <h3 class="text-white font-bold text-lg mb-4 flex items-center gap-2">
        <span class="text-violet-400">📜</span> Certificaciones Destacadas
      </h3>
      <div class="flex flex-wrap gap-3">
        {certifications.map((cert) => (
          <span class="text-xs font-medium text-slate-300 border border-neutral-700/60 bg-neutral-800/80 px-3 py-1.5 rounded-lg hover:border-violet-500/40 hover:text-white transition-all cursor-default">
            {cert}
          </span>
        ))}
      </div>
    </div>
  </div>
</section>