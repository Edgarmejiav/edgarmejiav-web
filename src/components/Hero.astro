---

<section id="hero" class="relative flex flex-col items-center justify-center min-h-screen gap-8 px-6 text-center overflow-hidden">
  <div class="absolute inset-0 -z-10 overflow-hidden pointer-events-none">
    <div class="blob blob-1"></div>
    <div class="blob blob-2"></div>
    <div class="blob blob-3"></div>
  </div>

  <div class="relative group">
    <div class="absolute -inset-1 rounded-full bg-gradient-to-br from-violet-500 via-cyan-400 to-lime-400 blur-md opacity-70 group-hover:opacity-100 transition-opacity duration-500"></div>
    <img
      width="120"
      height="120"
      class="relative rounded-full border-2 border-neutral-800 shadow-2xl"
      src="https://avatars.githubusercontent.com/u/35704346?v=4"
      alt="Edgar Mejía Vásquez"
    />
  </div>
  <div class="flex flex-wrap justify-center gap-2">
    <span class="inline-flex items-center gap-1.5 text-xs font-semibold px-3 py-1.5 rounded-full bg-violet-500/10 border border-violet-500/30 text-violet-300">🏢 Empresas Multinacionales</span>
    <span class="inline-flex items-center gap-1.5 text-xs font-semibold px-3 py-1.5 rounded-full bg-cyan-500/10 border border-cyan-500/30 text-cyan-300">🌐 100% Remoto</span>
    <span class="inline-flex items-center gap-1.5 text-xs font-semibold px-3 py-1.5 rounded-full bg-lime-500/10 border border-lime-500/30 text-lime-300">⚡ +4 años de experiencia</span>
  </div>

  <div class="flex flex-col items-center gap-3">
    <div class="flex items-center gap-3">
      <span class="inline-flex items-center gap-1.5 bg-emerald-500/10 border border-emerald-500/30 text-emerald-400 text-xs font-semibold px-3 py-1 rounded-full animate-pulse">
        <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 inline-block"></span>
        Disponible para trabajar
      </span>
    </div>

    <h1 class="text-5xl sm:text-7xl font-extrabold tracking-tight bg-gradient-to-br from-white via-slate-200 to-slate-400 text-transparent bg-clip-text leading-tight">
      Edgar Mejía<br />
      <span class="bg-gradient-to-r from-violet-400 via-cyan-400 to-lime-400 text-transparent bg-clip-text">
        Vásquez
      </span>
    </h1>

    <p class="text-xl sm:text-2xl text-slate-400 font-medium min-h-[2rem]" id="typing-role">
      <span class="text-cyan-400">&lt;</span>
      <span class="text-white font-mono" id="role-text"></span>
      <span class="animate-blink text-cyan-400 font-mono">|</span>
      <span class="text-cyan-400"> /&gt;</span>
    </p>
  </div>

  <div class="flex flex-wrap gap-4 justify-center">
    <a href="mailto:legamejiav@gmail.com" class="group relative inline-flex items-center gap-2 px-6 py-3 rounded-xl font-semibold text-sm bg-gradient-to-r from-violet-600 to-cyan-600 text-white shadow-lg shadow-violet-900/40 hover:shadow-cyan-900/60 hover:scale-105 transition-all duration-300">
      <span>✉️</span> Contáctame
    </a>
    <a href="https://www.linkedin.com/in/legamejiav/" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 px-6 py-3 rounded-xl font-semibold text-sm border border-neutral-700 text-slate-300 hover:border-cyan-500 hover:text-cyan-400 hover:scale-105 transition-all duration-300 bg-neutral-900/50 backdrop-blur">
      <span>💼</span> LinkedIn
    </a>
    <a href="https://github.com/edgarmejiav" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 px-6 py-3 rounded-xl font-semibold text-sm border border-neutral-700 text-slate-300 hover:border-lime-500 hover:text-lime-400 hover:scale-105 transition-all duration-300 bg-neutral-900/50 backdrop-blur">
      <span>⚡</span> GitHub
    </a>
  </div>

  <div class="absolute bottom-8 flex flex-col items-center gap-1 text-slate-600 text-xs animate-bounce">
    <span>scroll</span>
    <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
      <path d="M8 3v10M8 13l-3-3M8 13l3-3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path>
    </svg>
  </div>
</section>

<script>
  const roles = ["Software Engineer", "Backend Developer", "Frontend Developer", "Microservices Architect", "Tech Lead"];
  let roleIndex = 0;
  let charIndex = 0;
  let isDeleting = false;
  const roleText = document.getElementById('role-text');
  const speed = 90;
  const deleteSpeed = 50;
  const pauseTime = 1500;

  function typeEffect() {
    if (!roleText) return;
    const current = roles[roleIndex];
    
    if (!isDeleting) {
      roleText.textContent = current.substring(0, charIndex + 1);
      charIndex++;
      if (charIndex + 1 === current.length) {
        setTimeout(() => isDeleting = true, pauseTime);
      } else {
        setTimeout(typeEffect, isDeleting ? deleteSpeed : speed);
      }
    } else {
      roleText.textContent = current.substring(0, charIndex - 1);
      charIndex--;
      if (charIndex === 0) {
        isDeleting = false;
        roleIndex = (roleIndex + 1) % roles.length;
        setTimeout(typeEffect, speed);
      } else {
        setTimeout(typeEffect, deleteSpeed);
      }
    }
  }
  
  typeEffect();
</script>