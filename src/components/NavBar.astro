---
const navLinks = [
  { href: "#about", label: "Sobre Mí" },
  { href: "#stack", label: "Stack" },
  { href: "#experience", label: "Experiencia" },
  { href: "#projects", label: "Proyectos" },
];
---

<nav class="fixed top-0 z-50 w-full transition-all duration-500" id="navbar">
  <div class="max-w-6xl mx-auto flex items-center justify-between px-6 h-16">
    <a href="#hero" class="flex items-center gap-3 group" id="nav-logo">
      <div class="relative">
        <div class="absolute -inset-0.5 rounded-full bg-gradient-to-r from-violet-500 to-cyan-500 opacity-0 group-hover:opacity-80 blur transition-opacity duration-300"></div>
        <img
          width="34"
          height="34"
          class="relative rounded-full border border-neutral-700"
          src="https://avatars.githubusercontent.com/u/35704346?v=4"
          alt="Edgar"
        />
      </div>
      <span class="text-white font-bold text-sm hidden sm:block">
        Edgar<span class="text-cyan-400">MejiaV</span>
      </span>
    </a>

    <div class="hidden md:flex items-center gap-1">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class="text-slate-400 hover:text-white text-sm font-medium px-4 py-2 rounded-lg hover:bg-neutral-800/60 transition-all duration-200"
        >
          {link.label}
        </a>
      ))}
    </div>

    <div class="flex items-center gap-4">
      <div class="hidden sm:flex items-center">
        <slot name="social" />
      </div>
      <a
        href="https://www.linkedin.com/in/legamejiav/"
        target="_blank"
        class="hidden sm:flex items-center gap-1.5 bg-emerald-500/10 border border-emerald-500/30 text-emerald-400 text-xs font-semibold px-3 py-1.5 rounded-full hover:bg-emerald-500/20 transition-all duration-200"
      >
        <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 inline-block animate-pulse"></span>
        Open to work
      </a>

      <button
        class="md:hidden text-slate-400 hover:text-white p-2 rounded-lg hover:bg-neutral-800/60 transition-colors"
        id="mobile-menu-btn"
        aria-label="Toggle menu"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <line x1="4" y1="6" x2="20" y2="6"></line>
          <line x1="4" y1="12" x2="20" y2="12"></line>
          <line x1="4" y1="18" x2="20" y2="18"></line>
        </svg>
      </button>
    </div>
  </div>

  <div class="md:hidden bg-neutral-950/95 backdrop-blur-xl border-t border-neutral-800/60 px-6 py-4 flex flex-col gap-2 hidden" id="mobile-menu">
    {navLinks.map((link) => (
      <a
        href={link.href}
        class="text-slate-300 hover:text-white text-sm font-medium py-2 px-3 rounded-lg hover:bg-neutral-800/60 transition-all"
      >
        {link.label}
      </a>
    ))}
  </div>
</nav>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  
  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });

  const navbar = document.getElementById('navbar');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 20) {
      navbar?.classList.add('bg-neutral-950/90', 'backdrop-blur-xl', 'border-b', 'border-neutral-800/60', 'shadow-lg', 'shadow-black/30');
      navbar?.classList.remove('bg-transparent');
    } else {
      navbar?.classList.remove('bg-neutral-950/90', 'backdrop-blur-xl', 'border-b', 'border-neutral-800/60', 'shadow-lg', 'shadow-black/30');
      navbar?.classList.add('bg-transparent');
    }
  }, { passive: true });
</script>