---
import data from '../data.json';
import IconGitHubSmall from './icons/IconGitHubSmall.astro';
import IconLinkSmall from './icons/IconLinkSmall.astro';

const apps = data.filter((item) => !item?.type?.includes("tutorial"));
const tutorials = data.filter((item) => item?.type?.includes("tutorial"));

const gradients = [
  "from-white/5 to-white/5 border-white/10",
  "from-white/5 to-white/5 border-white/10",
  "from-white/5 to-white/5 border-white/10",
  "from-white/5 to-white/5 border-white/10",
  "from-white/5 to-white/5 border-white/10",
  "from-white/5 to-white/5 border-white/10",
  "from-white/5 to-white/5 border-white/10",
  "from-white/5 to-white/5 border-white/10",
];
---

<section id="projects" class="py-28 px-6">
  <div class="max-w-5xl mx-auto">
    <div class="flex items-center gap-4 mb-16">
      <div class="h-px flex-1 bg-gradient-to-r from-transparent to-white/10"></div>
      <h2 class="text-2xl md:text-3xl font-semibold text-white tracking-tight"><span class="text-white/40">04.</span> Proyectos</h2>
      <div class="h-px flex-1 bg-gradient-to-l from-transparent to-white/10"></div>
    </div>

    <div class="grid md:grid-cols-2 gap-4 mb-16">
      {apps.map((item, idx) => (
        <div class={`group relative rounded-2xl border bg-gradient-to-br ${gradients[idx % gradients.length]} backdrop-blur-sm p-5 hover:bg-white/5 transition-all duration-300 flex flex-col gap-3`}>
          <div class="flex items-center justify-between gap-2">
            <svg class="text-white/30" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <rect x="3" y="3" width="18" height="18" rx="2" />
              <path d="M3 9h18" />
            </svg>
            <div class="flex items-center gap-2">
              {item.github && (
                <a href={item.github} target="_blank" aria-label="GitHub" class="text-white/40 hover:text-white transition-colors">
                  <IconGitHubSmall />
                </a>
              )}
              {item.link && (
                <a href={item.link} target="_blank" aria-label="Live" class="text-white/40 hover:text-cyan-400 transition-colors">
                  <IconLinkSmall />
                </a>
              )}
              {item.youtube && (
                <a href={item.youtube} target="_blank" aria-label="YouTube" class="text-white/40 hover:text-red-400 transition-colors text-xs">▶</a>
              )}
            </div>
          </div>
          <div>
            <h3 class="text-white font-medium text-base capitalize">{item.title}</h3>
            <p class="text-[var(--text-secondary)] text-sm leading-relaxed mt-1">{item.description}</p>
          </div>
          <div class="flex flex-wrap gap-1.5 mt-auto pt-2">
            {item.stack.map((t) => (
              <span class="text-xs text-[var(--text-secondary)] border border-white/10 bg-white/5 px-2 py-0.5 rounded-md">{t}</span>
            ))}
          </div>
        </div>
      ))}
    </div>

    {tutorials.length > 0 && (
      <>
        <div class="flex items-center gap-4 mb-8">
          <div class="h-px flex-1 bg-white/10"></div>
          <h3 class="text-[var(--text-secondary)] text-sm font-medium uppercase tracking-widest">Demos</h3>
          <div class="h-px flex-1 bg-white/10"></div>
        </div>
        <div class="grid md:grid-cols-2 gap-4">
          {tutorials.map((item, idx) => (
            <div class={`group relative rounded-2xl border bg-gradient-to-br ${gradients[(idx + 4) % gradients.length]} backdrop-blur-sm p-5 hover:bg-white/5 transition-all duration-300 flex flex-col gap-3`}>
              <div class="flex items-center justify-between gap-2">
                <svg class="text-white/30" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                  <rect x="3" y="3" width="18" height="18" rx="2" />
                  <path d="M3 9h18" />
                </svg>
                <div class="flex items-center gap-2">
                  {item.github && (
                    <a href={item.github} target="_blank" aria-label="GitHub" class="text-white/40 hover:text-white transition-colors">
                      <IconGitHubSmall />
                    </a>
                  )}
                  {item.link && (
                    <a href={item.link} target="_blank" aria-label="Live" class="text-white/40 hover:text-cyan-400 transition-colors">
                      <IconLinkSmall />
                    </a>
                  )}
                  {item.youtube && (
                    <a href={item.youtube} target="_blank" aria-label="YouTube" class="text-white/40 hover:text-red-400 transition-colors text-xs">▶</a>
                  )}
                </div>
              </div>
              <div>
                <h3 class="text-white font-medium text-base capitalize">{item.title}</h3>
                <p class="text-[var(--text-secondary)] text-sm leading-relaxed mt-1">{item.description}</p>
              </div>
              <div class="flex flex-wrap gap-1.5 mt-auto pt-2">
                {item.stack.map((t) => (
                  <span class="text-xs text-[var(--text-secondary)] border border-white/10 bg-white/5 px-2 py-0.5 rounded-md">{t}</span>
                ))}
              </div>
            </div>
          ))}
        </div>
      </>
    )}
  </div>
</section>