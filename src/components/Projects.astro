---
import data from '../data.json';
import IconGitHubSmall from './icons/IconGitHubSmall.astro';
import IconLinkSmall from './icons/IconLinkSmall.astro';

const apps = data.filter((item) => !item?.type?.includes("tutorial"));
const tutorials = data.filter((item) => item?.type?.includes("tutorial"));

const gradients = [
  "from-violet-500/10 to-cyan-500/10 border-violet-500/20",
  "from-cyan-500/10 to-lime-500/10 border-cyan-500/20",
  "from-lime-500/10 to-emerald-500/10 border-lime-500/20",
  "from-pink-500/10 to-orange-500/10 border-pink-500/20",
  "from-blue-500/10 to-violet-500/10 border-blue-500/20",
  "from-orange-500/10 to-red-500/10 border-orange-500/20",
  "from-teal-500/10 to-cyan-500/10 border-teal-500/20",
  "from-amber-500/10 to-yellow-500/10 border-amber-500/20",
];
---

<section id="projects" class="py-24 px-6 bg-neutral-950/50">
  <div class="max-w-5xl mx-auto">
    <div class="flex items-center gap-4 mb-14">
      <div class="h-px flex-1 bg-gradient-to-r from-transparent to-pink-500/40"></div>
      <h2 class="section-title"><span class="text-pink-400">04.</span> Proyectos</h2>
      <div class="h-px flex-1 bg-gradient-to-l from-transparent to-pink-500/40"></div>
    </div>

    <div class="grid md:grid-cols-2 gap-5 mb-16">
      {apps.map((item, idx) => (
        <div class={`group relative rounded-2xl border bg-gradient-to-br ${gradients[idx % gradients.length]} backdrop-blur-sm p-6 hover:scale-[1.02] hover:shadow-xl transition-all duration-300 flex flex-col gap-4`}>
          <div class="flex items-center justify-between gap-2">
            <svg class="text-cyan-400 opacity-60" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <rect x="3" y="3" width="18" height="18" rx="2" />
              <path d="M3 9h18" />
            </svg>
            <div class="flex items-center gap-3">
              {item.github && (
                <a href={item.github} target="_blank" aria-label="GitHub" class="text-slate-400 hover:text-white group transition-colors">
                  <IconGitHubSmall />
                </a>
              )}
              {item.link && (
                <a href={item.link} target="_blank" aria-label="Live" class="text-slate-400 hover:text-cyan-400 group transition-colors">
                  <IconLinkSmall />
                </a>
              )}
              {item.youtube && (
                <a href={item.youtube} target="_blank" aria-label="YouTube" class="text-slate-400 hover:text-red-400 transition-colors text-sm">▶</a>
              )}
            </div>
          </div>
          <div>
            <h3 class="text-white font-bold text-lg capitalize group-hover:text-cyan-300 transition-colors">{item.title}</h3>
            <p class="text-slate-400 text-sm leading-relaxed mt-1.5">{item.description}</p>
          </div>
          <div class="flex flex-wrap gap-2 mt-auto pt-2">
            {item.stack.map((t) => (
              <span class="text-xs text-slate-400 border border-neutral-700/60 bg-neutral-900/50 px-2 py-0.5 rounded-md">{t}</span>
            ))}
          </div>
        </div>
      ))}
    </div>

    {tutorials.length > 0 && (
      <>
        <div class="flex items-center gap-4 mb-8">
          <div class="h-px flex-1 bg-neutral-800"></div>
          <h3 class="text-slate-400 text-sm font-semibold uppercase tracking-widest">Demos</h3>
          <div class="h-px flex-1 bg-neutral-800"></div>
        </div>
        <div class="grid md:grid-cols-2 gap-5">
          {tutorials.map((item, idx) => (
            <div class={`group relative rounded-2xl border bg-gradient-to-br ${gradients[(idx + 4) % gradients.length]} backdrop-blur-sm p-6 hover:scale-[1.02] hover:shadow-xl transition-all duration-300 flex flex-col gap-4`}>
              <div class="flex items-center justify-between gap-2">
                <svg class="text-cyan-400 opacity-60" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                  <rect x="3" y="3" width="18" height="18" rx="2" />
                  <path d="M3 9h18" />
                </svg>
                <div class="flex items-center gap-3">
                  {item.github && (
                    <a href={item.github} target="_blank" aria-label="GitHub" class="text-slate-400 hover:text-white group transition-colors">
                      <IconGitHubSmall />
                    </a>
                  )}
                  {item.link && (
                    <a href={item.link} target="_blank" aria-label="Live" class="text-slate-400 hover:text-cyan-400 group transition-colors">
                      <IconLinkSmall />
                    </a>
                  )}
                  {item.youtube && (
                    <a href={item.youtube} target="_blank" aria-label="YouTube" class="text-slate-400 hover:text-red-400 transition-colors text-sm">▶</a>
                  )}
                </div>
              </div>
              <div>
                <h3 class="text-white font-bold text-lg capitalize group-hover:text-cyan-300 transition-colors">{item.title}</h3>
                <p class="text-slate-400 text-sm leading-relaxed mt-1.5">{item.description}</p>
              </div>
              <div class="flex flex-wrap gap-2 mt-auto pt-2">
                {item.stack.map((t) => (
                  <span class="text-xs text-slate-400 border border-neutral-700/60 bg-neutral-900/50 px-2 py-0.5 rounded-md">{t}</span>
                ))}
              </div>
            </div>
          ))}
        </div>
      </>
    )}
  </div>
</section>