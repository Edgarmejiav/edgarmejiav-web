---
const techGroups = [
  { category: "Backend", icon: "⚙️", items: ["Java", "Python", "Node.js", ".NET", "Spring Boot", "FastAPI", "NestJS", "OAuth"] },
  { category: "Bases de Datos", icon: "🗄️", items: ["PostgreSQL", "MongoDB", "SQL"] },
  { category: "Frontend", icon: "🎨", items: ["JavaScript", "TypeScript", "React.js", "Vue.js", "Angular", "Redux.js", "Tailwind CSS", "Bootstrap", "Material-UI", "Styled-components", "HTML", "CSS", "Webpack", "Storybook", "HTTPS"] },
  { category: "CI/CD & Cloud", icon: "☁️", items: ["GitHub Actions", "Vercel", "AWS Amplify", "Azure Static Web Apps", "Docker", "Linux", "AWS S3", "AWS CloudFront"] },
  { category: "Pruebas y Calidad", icon: "🧪", items: ["Jest", "Storybook", "Selenium", "Mocha", "Chai", "Testing Library", "Postman", "ESLint", "Prettier"] },
  { category: "Gestión y Metodologías", icon: "📊", items: ["Scrum", "Kanban", "Agile", "Jira", "Notion", "Git"] },
];
---

<section id="stack" class="py-28 px-6">
  <div class="max-w-5xl mx-auto">
    <div class="flex items-center gap-4 mb-16">
      <div class="h-px flex-1 bg-gradient-to-r from-transparent to-white/10"></div>
      <h2 class="text-2xl md:text-3xl font-semibold text-white tracking-tight"><span class="text-white/40">02.</span> Stack Tecnológico</h2>
      <div class="h-px flex-1 bg-gradient-to-l from-transparent to-white/10"></div>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4">
      {techGroups.map((group) => (
        <div class="glass-card rounded-2xl p-5 hover:bg-white/5 transition-all duration-300">
          <div class="flex items-center gap-3 mb-4">
            <span class="text-xl opacity-80">{group.icon}</span>
            <h3 class="text-white font-medium text-base">{group.category}</h3>
          </div>
          <div class="flex flex-wrap gap-2">
            {group.items.map((tech) => (
              <span class="text-xs font-medium text-[var(--text-secondary)] bg-white/5 border border-white/10 rounded-lg px-2.5 py-1 hover:bg-white/10 hover:text-white transition-all duration-200 cursor-default">
                {tech}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>