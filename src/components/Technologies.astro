---

<div class="absolute inset-0 z-[-1] overflow-hidden pointer-events-none opacity-10">
    <div id="tech-icons" class="relative w-full h-full [&>svg]:absolute [&>svg]:p-4 [&>svg]:w-14 [&>svg]:h-14 [&>svg]:opacity-0">
        {techIcons.map(({ name, color, path }) => (
            <svg key={name} viewBox="0 0 24 24" fill={color} role="img" aria-label={name}>
                <path d={path} />
            </svg>
        ))}
    </div>
</div>

<script>
    function initTechnologies() {
        const container = document.getElementById('tech-icons');
        if (!container) return;

        const svgs = Array.from(container.querySelectorAll('svg'));
        
        const animateOne = () => {
            const available = svgs.filter(s => !s.classList.contains('is-animating'));
            if (!available.length) return;

            const svg = available[Math.floor(Math.random() * available.length)];
            const maxX = window.innerWidth - 100;
            const maxY = window.innerHeight - 200;

            svg.style.top = `${Math.floor(Math.random() * maxY)}px`;
            svg.style.left = `${Math.floor(Math.random() * maxX)}px`;
            svg.classList.add('animate-float', 'is-animating');

            svg.addEventListener('animationend', () => {
                svg.classList.remove('animate-float', 'is-animating');
                svg.style.removeProperty('top');
                svg.style.removeProperty('left');
            }, { once: true });
        };

        svgs.forEach((_, i) => setTimeout(animateOne, i * 400));
        setInterval(animateOne, 1800);
    }
    
    initTechnologies();
</script>

<style>
    @keyframes float {
        0%, 100% { transform: translateY(0) rotate(0deg); opacity: 0; }
        10% { opacity: 1; }
        90% { opacity: 1; }
        100% { transform: translateY(-30px) rotate(10deg); opacity: 0; }
    }
    .animate-float {
        animation: float 6s ease-in-out forwards;
    }
</style>